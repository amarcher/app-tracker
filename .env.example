# GA4 Data API — service account credentials
GOOGLE_APPLICATION_CREDENTIALS=./ga4-key.json
GA4_KEY_JSON=                          # Alternative: inline JSON (for Vercel)

# GA4 Property IDs — one per monitored project
GA4_PROPERTY_ID=                       # Animal Pen Pals
GA4_PROPERTY_ID_SPACE_EXPLORER=
GA4_PROPERTY_ID_PERIODIC_TABLE=
GA4_PROPERTY_ID_CROSSWORD_CLASH=
GA4_PROPERTY_ID_TICKET_FOR_DINNER=
GA4_PROPERTY_ID_SUPERBOWL_SQUARES=
GA4_PROPERTY_ID_TABBIT_RABBIT=
GA4_PROPERTY_ID_MARK_MY_WORDS=

# ElevenLabs — account-wide usage stats
ELEVENLABS_API_KEY=

# ElevenLabs Conversational AI — per-project agent IDs (optional)
# Each of these maps a project key to an ElevenLabs agent. Leave unset to
# disable the Conversational AI section for that project.
ELEVENLABS_AGENT_ID_ANIMAL_PENPALS=
ELEVENLABS_AGENT_ID_SPACE_EXPLORER=
ELEVENLABS_AGENT_ID_PERIODIC_TABLE=
ELEVENLABS_AGENT_ID_CROSSWORD_CLASH=
ELEVENLABS_AGENT_ID_MARK_MY_WORDS=

# Neon Postgres — self-instrumented API usage logs
DATABASE_URL=

# Cloudflare — CDN and R2 stats (per-project)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID_ANIMAL_PENPALS=
CLOUDFLARE_ZONE_ID_PERIODIC_TABLE=
# CLOUDFLARE_ZONE_ID_SPACE_EXPLORER=   # when active

# Also set DASHBOARD_DATABASE_URL on each monitored project's hosting platform
